[Unit]
Description=Trend Syria Backend API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/trend-syria-app/backend
Environment=PATH=/root/trend-syria-app/backend/venv/bin:/usr/bin
ExecStart=/root/trend-syria-app/backend/venv/bin/uvicorn server:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
